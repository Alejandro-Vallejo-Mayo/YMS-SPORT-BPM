  "variables" : {
    "task" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}"
      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.gestion_incidencia ){",
        "\treturn {",
        "\t\t//map gestion_incidencia variable to expected task contract input",
        "\t\tgestion_incidenciaInput: {",
        "\t\t\tarticulo: $data.gestion_incidencia.articulo !== undefined ? $data.gestion_incidencia.articulo : null,",
        "\t\t\testado: $data.gestion_incidencia.estado !== undefined ? $data.gestion_incidencia.estado : null,",
        "\t\t\tdescripcion: $data.gestion_incidencia.descripcion !== undefined ? $data.gestion_incidencia.descripcion : null,",
        "\t\t\tcoste_reparacion: $data.gestion_incidencia.coste_reparacion !== undefined ? $data.gestion_incidencia.coste_reparacion : null,",
        "\t\t\taprobacion_gerencia: $data.gestion_incidencia.aprobacion_gerencia !== undefined ? $data.gestion_incidencia.aprobacion_gerencia : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "gestion_incidencia" : {
      "type" : "url",
      "value" : [
        "../{{context.gestion_incidencia_ref.link}}"
      ],
      "exposed" : false
    },
    "taskId" : {
      "type" : "urlparameter",
      "value" : [
        "id"
      ],
      "exposed" : false
    }
