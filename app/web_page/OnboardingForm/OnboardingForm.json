        "\t\tcontratacion_nuevo_empleadoInput: {",
        "\t\t\tnombre: $data.contratacion_nuevo_empleado.nombre !== undefined ? $data.contratacion_nuevo_empleado.nombre : null,",
        "\t\t\tapellidos: $data.contratacion_nuevo_empleado.apellidos !== undefined ? $data.contratacion_nuevo_empleado.apellidos : null,",
        "\t\t\tfecha_nacimiento: $data.contratacion_nuevo_empleado.fecha_nacimiento !== undefined ? $data.contratacion_nuevo_empleado.fecha_nacimiento : null,",
        "\t\t\tcorreo: $data.contratacion_nuevo_empleado.correo !== undefined ? $data.contratacion_nuevo_empleado.correo : null,",
        "\t\t\ttelefono: $data.contratacion_nuevo_empleado.telefono !== undefined ? $data.contratacion_nuevo_empleado.telefono : null,",
        "\t\t\tdni: $data.contratacion_nuevo_empleado.dni !== undefined ? $data.contratacion_nuevo_empleado.dni : null,",
        "\t\t\tiban: $data.contratacion_nuevo_empleado.iban !== undefined ? $data.contratacion_nuevo_empleado.iban : null,",
        "\t\t\tpuesto_trabajo: $data.contratacion_nuevo_empleado.puesto_trabajo !== undefined ? $data.contratacion_nuevo_empleado.puesto_trabajo : null,",
        "\t\t\tonboarding: $data.contratacion_nuevo_empleado.onboarding !== undefined ? $data.contratacion_nuevo_empleado.onboarding : null,",
        "\t\t\tformacion: $data.contratacion_nuevo_empleado.formacion !== undefined ? $data.contratacion_nuevo_empleado.formacion : null",
