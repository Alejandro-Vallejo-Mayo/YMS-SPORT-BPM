        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.baja_socio ){",
        "\treturn {",
        "\t\t//map baja_socio variable to expected task contract input",
        "\t\tbaja_socioInput: {",
