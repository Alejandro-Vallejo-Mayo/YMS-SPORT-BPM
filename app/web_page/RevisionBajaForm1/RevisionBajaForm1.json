      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.baja_socio ){",
        "\treturn {",
        "\t\t//map baja_socio variable to expected task contract input",
        "\t\tbaja_socioInput: {",
        "\t\t\tdni: $data.baja_socio.dni !== undefined ? $data.baja_socio.dni : null,",
        "\t\t\tcorreo: $data.baja_socio.correo !== undefined ? $data.baja_socio.correo : null,",
        "\t\t\tmotivo: $data.baja_socio.motivo !== undefined ? $data.baja_socio.motivo : null,",
        "\t\t\tretencion: $data.baja_socio.retencion !== undefined ? $data.baja_socio.retencion : null,",
        "\t\t\tcondiciones_retencion: $data.baja_socio.condiciones_retencion !== undefined ? $data.baja_socio.condiciones_retencion : null,",
        "\t\t\tacepta_retencion: $data.baja_socio.acepta_retencion !== undefined ? $data.baja_socio.acepta_retencion : null",
        "\t\t}",
        "\t}",
        "}"
      ],
